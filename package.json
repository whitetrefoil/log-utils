{
  "name": "@whitetrefoil/log-utils",
  "version": "0.15.0",
  "type": "module",
  "author": "WhiteTrefoil <whitetrefoil@gmail.com>",
  "license": "Unlicense",
  "description": "A set of utilities for logging base on `loglevel` & `debug`.",
  "keywords": [
    "log",
    "console",
    "loglevel",
    "debug"
  ],
  "files": [
    "lib"
  ],
  "exports": {
    ".": "./lib/main.js"
  },
  "scripts": {
    "prepare": "echo 'This package must be published via Yarn, not NPM' && exit 1",
    "prepack": "yarn build",
    "build": "rimraf lib && tsc -p src/tsconfig.json --noEmit false",
    "test": "rimraf test_results && vitest run; eslint src tests",
    "watch": "rimraf lib && tsc -p src/tsconfig.json --noEmit false -w"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/whitetrefoil/log-utils.git"
  },
  "engines": {
    "node": ">=24"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "imports": {
    "#/*": "./src/*"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "debug": "^4.4.3",
    "slash": "^5.1.0",
    "strip-ansi": "^7.2.0",
    "supports-color": "^10.2.2",
    "time-stamp": "^2.2.0"
  },
  "devDependencies": {
    "@colbymchenry/codegraph": "^1.1.6",
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.2",
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/debug": "^4.1.13",
    "@types/node": "^26.0.1",
    "@typescript/native-preview": "^7.0.0-dev.20260629.1",
    "@vitest/coverage-v8": "^4.1.9",
    "@whitetrefoil/eslint-config": "^14.0.0",
    "eslint": "^10.6.0",
    "eslint-plugin-n": "^18.2.1",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.0",
    "vite-plugin-eslint2": "^5.3.0",
    "vitest": "^4.1.9",
    "yaml": "^2.9.0"
  },
  "packageManager": "yarn@4.17.0"
}
